---

---

<section class="block block-prompt">
	<p class="cmd-line">
		<span class="prompt" aria-hidden="true">$</span>
		<span class="cursor"></span>
	</p>
</section>

<style>
	.block {
		margin-bottom: 2rem;
	}

	.cmd-line {
		margin: 0;
		font-size: 0.88rem;
		white-space: pre-wrap;
	}

	.prompt {
		color: #39ff14;
		font-weight: 700;
		margin-right: 0.5rem;
		user-select: none;
	}

	.cursor {
		display: inline-block;
		width: 0.55em;
		height: 1.1em;
		background: #39ff14;
		vertical-align: text-bottom;
		animation: blink 1s step-end infinite;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor {
			animation: none;
			opacity: 1;
		}
	}
</style>
