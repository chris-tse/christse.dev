---
interface Props {
	title?: string
}

const { title = 'christse@portfolio ~' } = Astro.props
---

<div class="terminal">
	<header class="terminal-bar">
		<div class="bar-dots">
			<span class="dot dot-red"></span>
			<span class="dot dot-yellow"></span>
			<span class="dot dot-green"></span>
		</div>
		<p class="bar-title">{title}</p>
		<div class="bar-spacer"></div>
	</header>

	<main class="terminal-body">
		<slot />
	</main>
</div>

<style>
	.terminal {
		width: min(960px, calc(100vw - 2rem));
		margin: 2rem auto 0;
		border: 1px solid #1d2433;
		border-radius: 8px 8px 0 0;
		overflow: hidden;
		box-shadow:
			0 0 80px rgba(57, 255, 20, 0.04),
			0 2px 40px rgba(0, 0, 0, 0.5);
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 1rem;
		background: #151a24;
		border-bottom: 1px solid #1d2433;
	}

	.bar-dots {
		display: flex;
		gap: 6px;
	}

	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}

	.dot-red {
		background: #ff5f57;
	}

	.dot-yellow {
		background: #febc2e;
	}

	.dot-green {
		background: #28c840;
	}

	.bar-title {
		margin: 0;
		font-size: 0.72rem;
		color: #5c6773;
		letter-spacing: 0.03em;
	}

	.bar-spacer {
		flex: 1;
	}

	.terminal-body {
		padding: 1.5rem;
		background: #0d1117;
		min-height: 60vh;
	}

	/* ── Responsive ── */
	@media (max-width: 700px) {
		.terminal {
			width: calc(100vw - 1rem);
			margin: 0.5rem auto 0;
			border-radius: 0;
		}

		.terminal-body {
			padding: 1rem;
		}
	}
</style>
