---
interface Props {
	title?: string
}

const { title = 'christse@portfolio ~' } = Astro.props
---

<div class="terminal">
	<header class="terminal-bar">
		<div class="bar-dots" aria-hidden="true">
			<span class="dot dot-red"></span>
			<span class="dot dot-yellow"></span>
			<span class="dot dot-green"></span>
		</div>
		<p class="bar-title">{title}</p>
		<div class="bar-spacer"></div>
		<slot name="nav" />
	</header>

	<main class="terminal-body">
		<slot />
	</main>
</div>

<style>
	.terminal {
		width: min(var(--term-max-width), calc(100vw - 2rem));
		margin: 2rem auto 0;
		border: 1px solid var(--term-border);
		border-radius: 8px 8px 0 0;
		overflow: hidden;
		box-shadow:
			0 0 80px rgb(var(--term-green-rgb) / 0.04),
			0 2px 40px rgb(var(--term-shadow-rgb) / 0.5);
	}

	.terminal-bar {
		position: relative;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 1rem;
		background: var(--term-bg-bar);
		border-bottom: 1px solid var(--term-border);
	}

	.bar-dots {
		display: flex;
		gap: 6px;
	}

	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}

	.dot-red {
		background: var(--term-dot-red);
	}

	.dot-yellow {
		background: var(--term-dot-yellow);
	}

	.dot-green {
		background: var(--term-dot-green);
	}

	.bar-title {
		margin: 0;
		font-size: 0.72rem;
		color: var(--term-text-muted);
		letter-spacing: 0.03em;
	}

	.bar-spacer {
		flex: 1;
	}

	.terminal-body {
		padding: 1.5rem;
		background: var(--term-bg-body);
		min-height: 60vh;
	}

	/* ── Responsive ── */
	@media (max-width: 700px) {
		.terminal {
			width: calc(100vw - 1rem);
			margin: 0.5rem auto 0;
			border-radius: 0;
		}

		.terminal-body {
			padding: 1rem;
		}
	}

	@media (max-width: 480px) {
		.terminal {
			width: 100vw;
			margin: 0 auto;
		}

		.terminal-body {
			padding: 0.75rem;
		}
	}
</style>
