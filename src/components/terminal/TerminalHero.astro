---
interface Props {
	asciiName: string[]
}

const { asciiName } = Astro.props
---

<section class="block block-ascii" aria-label="Chris Tse">
	<div class="ascii-art">
		{asciiName.map((line) => <pre>{line}</pre>)}
	</div>
	<p class="cmd-line">
		<span class="prompt" aria-hidden="true">$</span> cat tagline.md
	</p>
	<div class="output md-output">
		<p class="md-heading">
			<span class="md-hash" aria-hidden="true">##</span> Frontend Engineer
		</p>
		<p>
			I build accessible, high-performance interfaces with a strong bias toward
			clarity and speed. From performance audits to greenfield launches, I focus
			on making experiences feel fast and teams more productive.
		</p>
	</div>
</section>

<style>
	/* Component-specific styles only — shared classes from terminal.css */
	.ascii-art {
		overflow-x: auto;
		margin-bottom: 0.75rem;
	}

	.ascii-art pre {
		margin: 0;
		font-size: clamp(0.38rem, 1.1vw, 0.68rem);
		line-height: 1.15;
		color: var(--term-green);
		text-shadow: 0 0 12px rgba(57, 255, 20, 0.3);
		white-space: pre;
	}

	@media (max-width: 700px) {
		.ascii-art pre {
			font-size: clamp(0.26rem, 1.4vw, 0.5rem);
		}
	}
</style>
