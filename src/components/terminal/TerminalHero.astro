---
interface Props {
	asciiName: string[]
}

const { asciiName } = Astro.props
---

<section class="block block-ascii" aria-label="Chris Tse">
	<div class="ascii-art">
		{asciiName.map((line) => <pre>{line}</pre>)}
	</div>
	<p class="cmd-line">
		<span class="prompt" aria-hidden="true">$</span> cat tagline.md
	</p>
	<div class="output md-output">
		<p class="md-heading">
			<span class="md-hash" aria-hidden="true">##</span> Frontend Engineer
		</p>
		<p>
			I build accessible, high-performance interfaces with a strong bias toward
			clarity and speed. From performance audits to greenfield launches, I focus
			on making experiences feel fast and teams more productive.
		</p>
	</div>
</section>

<style>
	.block {
		margin-bottom: 2rem;
	}

	.cmd-line {
		margin: 0;
		font-size: 0.88rem;
		white-space: pre-wrap;
	}

	.prompt {
		color: #39ff14;
		font-weight: 700;
		margin-right: 0.5rem;
		user-select: none;
	}

	.output {
		margin: 0.5rem 0 0 1.25rem;
		padding-left: 0.75rem;
		border-left: 2px solid #1d2433;
		color: #acb2c0;
		font-size: 0.88rem;
	}

	.output p {
		margin: 0;
		max-width: 68ch;
	}

	.ascii-art {
		overflow-x: auto;
		margin-bottom: 0.75rem;
	}

	.ascii-art pre {
		margin: 0;
		font-size: clamp(0.38rem, 1.1vw, 0.68rem);
		line-height: 1.15;
		color: #39ff14;
		text-shadow: 0 0 12px rgba(57, 255, 20, 0.3);
		white-space: pre;
	}

	.md-output p {
		margin: 0;
	}

	.md-heading {
		font-size: 1.2rem;
		font-weight: 700;
		color: #e6e1cf;
		margin-bottom: 0.4rem;
	}

	.md-hash {
		color: #5c6773;
		margin-right: 0.35rem;
		font-weight: 400;
	}

	@media (max-width: 700px) {
		.ascii-art pre {
			font-size: clamp(0.26rem, 1.4vw, 0.5rem);
		}
	}
</style>
