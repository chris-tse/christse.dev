---
import CareerSubagent from './CareerSubagent.astro'
import type { WorkHistoryItem } from '../../types'

interface Props {
	workHistory: WorkHistoryItem[]
}

const { workHistory } = Astro.props

// Reverse for display order (oldest to newest)
const displayHistory = [...workHistory].reverse()
---

<section class="block block-career">
	<p class="cmd-line typed">
		<span class="prompt" aria-hidden="true">$</span> todo list --career
		<span class="cmd-meta">({displayHistory.length} items)</span>
	</p>
	<div class="output">
		<div class="todo-list" role="list" aria-label="Career history">
			{
				displayHistory.map((job, i, arr) => {
					const isActive = i === arr.length - 1
					const jobId = `job-${i}`
					return (
						<div
							id={jobId}
							class={`todo-item ${isActive ? 'in-progress' : 'done'} ${isActive ? 'expanded' : 'collapsed'}`}
							data-job-index={i}
							data-is-active={isActive}
							role="listitem"
						>
							<span class="todo-check" aria-hidden="true">
								{isActive ? '>' : 'x'}
							</span>
							<div class="todo-content">
								<button
									class="todo-header-btn"
									type="button"
									aria-expanded={isActive}
									aria-controls={`${jobId}-details`}
								>
									<div class="todo-title-row">
										<span class="todo-title">
											{job.title} @ {job.employer}
										</span>
										<span
											class={`todo-badge ${isActive ? 'badge-active' : 'badge-done'}`}
										>
											{isActive ? 'in_progress' : 'completed'}
										</span>
									</div>
									<span class="todo-meta">{job.dateRange}</span>
									<span class="expand-hint" aria-hidden="true">
										{isActive ? '[click to collapse]' : '[click to expand]'}
									</span>
								</button>
								<div id={`${jobId}-details`} class="todo-details">
									<CareerSubagent
										company={job.employer}
										descriptions={job.description}
									/>
								</div>
							</div>
						</div>
					)
				})
			}
		</div>
	</div>
</section>

<script>
	function initCareerExpansion() {
		const todoItems = document.querySelectorAll('.todo-item')

		todoItems.forEach((item) => {
			const btn = item.querySelector('.todo-header-btn')
			const details = item.querySelector('.todo-details')
			const hint = item.querySelector('.expand-hint')

			if (!btn || !details) return

			btn.addEventListener('click', () => {
				const isExpanded = item.classList.contains('expanded')

				if (isExpanded) {
					item.classList.remove('expanded')
					item.classList.add('collapsed')
					btn.setAttribute('aria-expanded', 'false')
					if (hint) hint.textContent = '[click to expand]'
				} else {
					item.classList.remove('collapsed')
					item.classList.add('expanded')
					btn.setAttribute('aria-expanded', 'true')
					if (hint) hint.textContent = '[click to collapse]'
				}
			})
		})
	}

	// Initialize on DOM ready
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initCareerExpansion)
	} else {
		initCareerExpansion()
	}
</script>

<style>
	/* Component-specific styles only — shared classes from terminal.css */

	.cmd-meta {
		margin-left: 0.5rem;
		font-size: 0.75rem;
		color: var(--term-text-disabled);
	}

	/* ── Career todo list ── */
	.todo-list {
		display: grid;
		gap: 0;
		font-size: 0.86rem;
	}

	.todo-item {
		display: flex;
		align-items: flex-start;
		gap: 0.65rem;
		padding: 0.55rem 0;
		border-bottom: 1px dashed var(--term-border-dashed);
	}

	.todo-item.done {
		opacity: 0.7;
	}

	.todo-item.in-progress {
		opacity: 1;
		background: linear-gradient(
			90deg,
			rgb(var(--term-blue-rgb) / 0.04) 0%,
			transparent 100%
		);
		border-bottom: none;
	}

	.todo-check {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.4rem;
		height: 1.4rem;
		border-radius: 3px;
		font-size: 0.72rem;
		font-weight: 800;
		margin-top: 0.1rem;
		line-height: 1;
	}

	.done .todo-check {
		border: 1px solid var(--term-border-subtle);
		color: var(--term-text-disabled);
		background: var(--term-bg-deepest);
		text-decoration: line-through;
	}

	.in-progress .todo-check {
		border: 1px solid var(--term-blue);
		color: var(--term-blue);
		background: var(--term-bg-hover);
		animation: pulse-glow 2s ease-in-out infinite;
	}

	@keyframes pulse-glow {
		0%,
		100% {
			box-shadow: 0 0 4px rgb(var(--term-blue-rgb) / 0.15);
		}
		50% {
			box-shadow: 0 0 10px rgb(var(--term-blue-rgb) / 0.35);
		}
	}

	.todo-content {
		flex: 1;
		min-width: 0;
	}

	.todo-header-btn {
		display: block;
		width: 100%;
		background: transparent;
		border: none;
		padding: 0;
		text-align: left;
		cursor: pointer;
		color: inherit;
		font-family: inherit;
		font-size: inherit;
	}

	.todo-header-btn:hover .todo-title,
	.todo-header-btn:focus .todo-title {
		color: var(--term-blue);
	}

	.todo-header-btn:focus {
		outline: 2px solid var(--term-blue);
		outline-offset: 2px;
	}

	.todo-title-row {
		display: flex;
		align-items: baseline;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.todo-title {
		color: var(--term-text-output);
		font-weight: 500;
		transition: color 0.15s ease;
	}

	.done .todo-title {
		color: var(--term-text-muted);
	}

	.in-progress .todo-title {
		color: var(--term-text-bright);
		text-decoration: none;
		font-weight: 600;
	}

	.todo-badge {
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.12rem 0.45rem;
		border-radius: 3px;
	}

	.badge-done {
		color: var(--term-text-disabled);
		background: var(--term-bg-badge-dark);
		border: 1px solid var(--term-border);
	}

	.badge-active {
		color: var(--term-blue);
		background: var(--term-bg-hover);
		border: 1px solid var(--term-blue-border);
	}

	.todo-meta {
		display: block;
		margin-top: 0.15rem;
		font-size: 0.72rem;
		color: var(--term-text-disabled);
		letter-spacing: 0.04em;
	}

	.in-progress .todo-meta {
		color: var(--term-text-muted);
	}

	.expand-hint {
		display: block;
		margin-top: 0.25rem;
		font-size: 0.68rem;
		color: var(--term-text-disabled);
		font-style: italic;
		opacity: 0.7;
		transition: opacity 0.15s ease;
	}

	.todo-header-btn:hover .expand-hint,
	.todo-header-btn:focus .expand-hint {
		opacity: 1;
	}

	/* Collapsed state */
	.todo-item.collapsed .todo-details {
		display: none;
	}

	/* Expanded state */
	.todo-item.expanded .todo-details {
		display: block;
		margin-top: 0.5rem;
		animation: expand-in 0.2s ease-out;
	}

	@keyframes expand-in {
		from {
			opacity: 0;
			transform: translateY(-4px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 700px) {
		.todo-title-row {
			flex-direction: column;
			gap: 0.25rem;
		}
	}

	@media (max-width: 480px) {
		.todo-item {
			gap: 0.4rem;
		}

		.todo-check {
			width: 1.1rem;
			height: 1.1rem;
			font-size: 0.62rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.in-progress .todo-check {
			animation: none;
		}

		.todo-item.expanded .todo-details {
			animation: none;
		}

		.todo-title {
			transition: none;
		}

		.expand-hint {
			transition: none;
		}
	}
</style>
