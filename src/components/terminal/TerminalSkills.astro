---
import { Folder } from 'lucide-astro'

interface Props {
	skills: string[]
}

const { skills } = Astro.props
---

<section class="block block-skills" aria-label="Skills">
	<p class="cmd-line typed">
		<span class="prompt" aria-hidden="true">$</span> eza --icons ~/skills/
	</p>
	<div class="output skill-grid">
		{
			skills.map((skill, i) => (
				<span class="skill-item" style={`--i: ${i}`}>
					<Folder size={14} aria-hidden="true" class="skill-icon" />
					{skill}
				</span>
			))
		}
	</div>
</section>

<style>
	/* eza-style grid layout with folder icons */
	.skill-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
		gap: 0.4rem 1rem;
		font-size: 0.88rem;
	}

	.skill-item {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--term-blue);
		font-size: 0.88rem;
		font-weight: 600;
	}

	.skill-item :global(svg) {
		color: var(--term-blue);
		flex-shrink: 0;
		display: inline;
	}

	@media (max-width: 700px) {
		.skill-grid {
			grid-template-columns: repeat(auto-fill, minmax(8rem, 1fr));
		}
	}

	@media (max-width: 480px) {
		.skill-grid {
			margin-left: 0.25rem;
			padding-left: 0.35rem;
			gap: 0.3rem 0.6rem;
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
