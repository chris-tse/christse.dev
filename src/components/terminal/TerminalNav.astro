---
import { Sun, Moon } from 'lucide-astro'

interface Props {
	hrefs?: {
		home?: string
		uses?: string
		blog?: string
	}
}

const { hrefs: { home = '/', uses = '/uses', blog = '/blog' } = {} } =
	Astro.props

const currentPath = Astro.url.pathname
const isBlogRoute = currentPath.startsWith('/blog')
const isUsesRoute = currentPath.startsWith('/uses')
const navMenuId = `nav-links-${currentPath.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '') || 'home'}`
---

<a href="#main-content" class="skip-link">Skip to content</a>

<nav
	class="terminal-nav"
	aria-label="Main navigation"
	data-terminal-nav
	data-open="false"
>
	<button
		type="button"
		class="nav-toggle-button"
		aria-label="Toggle menu"
		aria-expanded="false"
		aria-controls={navMenuId}
		data-nav-toggle
	>
		<span class="nav-toggle-icon" aria-hidden="true">[menu]</span>
		<span class="nav-toggle-icon-close" aria-hidden="true">[x]</span>
	</button>

	<div class="nav-links" id={navMenuId} data-nav-links>
		<a
			href={home}
			class:list={['nav-link', { active: !isBlogRoute && !isUsesRoute }]}
			>[index]</a
		>
		<a href={uses} class:list={['nav-link', { active: isUsesRoute }]}>[uses]</a>
		<a href={blog} class:list={['nav-link', { active: isBlogRoute }]}>[blog]</a>
		<button
			type="button"
			class="nav-link theme-toggle"
			id="theme-toggle"
			aria-label="Toggle theme"
			title="Toggle theme"
			>[theme <span class="theme-icon" aria-hidden="true"
				><span class="icon-sun"><Sun size={14} /></span><span class="icon-moon"
					><Moon size={14} /></span
				></span
			>]</button
		>
	</div>
</nav>

<script>
	// ── Nav menu toggle ──
	const initNav = () => {
		const root = document.querySelector<HTMLElement>('[data-terminal-nav]')
		if (!root) return

		const toggle = root.querySelector<HTMLButtonElement>('[data-nav-toggle]')
		const links = root.querySelector<HTMLElement>('[data-nav-links]')
		if (!toggle || !links) return

		const mediaQuery = window.matchMedia('(max-width: 700px)')

		const setOpen = (open: boolean) => {
			root.dataset.open = String(open)
			toggle.setAttribute('aria-expanded', String(open))
		}

		setOpen(false)

		toggle.addEventListener('click', () =>
			setOpen(root.dataset.open !== 'true'),
		)

		root.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && root.dataset.open === 'true') {
				setOpen(false)
				toggle.focus()
			}
		})

		links.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => setOpen(false))
		})

		document.addEventListener('click', (event) => {
			if (
				root.dataset.open === 'true' &&
				!root.contains(event.target as Node)
			) {
				setOpen(false)
			}
		})

		mediaQuery.addEventListener('change', () => {
			if (!mediaQuery.matches) setOpen(false)
		})
	}

	// ── Theme toggle ──
	const getTheme = () =>
		localStorage.getItem('theme') ||
		(window.matchMedia('(prefers-color-scheme: light)').matches
			? 'light'
			: 'dark')

	const applyTheme = (t: string) => {
		document.documentElement.dataset.theme = t
		localStorage.setItem('theme', t)
		document
			.querySelectorAll<HTMLButtonElement>('#theme-toggle')
			.forEach((btn) => {
				btn.setAttribute(
					'aria-label',
					t === 'light' ? 'Switch to dark theme' : 'Switch to light theme',
				)
				btn.dataset.theme = t
			})
	}

	const initThemeToggle = () => {
		const btn = document.querySelector<HTMLButtonElement>('#theme-toggle')
		if (!btn) return
		btn.addEventListener('click', () =>
			applyTheme(getTheme() === 'light' ? 'dark' : 'light'),
		)
	}

	// astro:page-load fires on first load and after every view transition
	document.addEventListener('astro:page-load', () => {
		applyTheme(getTheme())
		initNav()
		initThemeToggle()
	})

	window
		.matchMedia('(prefers-color-scheme: light)')
		.addEventListener('change', (e) => {
			if (!localStorage.getItem('theme'))
				applyTheme(e.matches ? 'light' : 'dark')
		})
</script>

<style>
	/* ── Skip link ── */
	.skip-link {
		position: absolute;
		top: -100%;
		left: 0;
		z-index: 200;
		padding: 0.5rem 1rem;
		background: var(--term-bg-body);
		color: var(--term-green);
		font-size: 0.85rem;
		text-decoration: none;
		border: 1px solid var(--term-green);
		border-radius: 0 0 4px 0;
	}

	.skip-link:focus {
		top: 0;
	}

	/* ── Nav container ── */
	.terminal-nav {
		position: relative;
		display: flex;
		align-items: center;
		gap: 0.25rem;
		margin-left: auto;
	}

	/* ── Toggle button (mobile only) ── */
	.nav-toggle-button {
		display: none;
		cursor: pointer;
		border: 0;
		background: transparent;
		color: var(--term-text-muted);
		font-size: 0.72rem;
		letter-spacing: 0.03em;
		padding: 0.2rem 0.4rem;
		border-radius: 3px;
		transition: color 0.2s;
		user-select: none;
	}

	.nav-toggle-button:hover,
	.nav-toggle-button:focus-visible {
		color: var(--term-text);
	}

	.nav-toggle-button:focus-visible {
		outline: 1px solid var(--term-green);
		outline-offset: 1px;
	}

	.nav-toggle-icon-close {
		display: none;
	}

	.nav-toggle-button[aria-expanded='true'] .nav-toggle-icon {
		display: none;
	}

	.nav-toggle-button[aria-expanded='true'] .nav-toggle-icon-close {
		display: inline;
	}

	/* ── Nav links ── */
	.nav-links {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}

	.nav-link {
		color: var(--term-text-muted);
		text-decoration: none;
		font-size: 0.72rem;
		letter-spacing: 0.03em;
		padding: 0.2rem 0.4rem;
		border-radius: 3px;
		transition:
			color 0.2s,
			background-color 0.2s;
		white-space: nowrap;
	}

	.nav-link:hover,
	.nav-link:focus-visible {
		color: var(--term-green);
		background-color: rgb(var(--term-green-rgb) / 0.06);
	}

	.nav-link:focus-visible {
		outline: 1px solid var(--term-green);
		outline-offset: 1px;
	}

	.nav-link.active {
		color: var(--term-text);
	}

	/* ── Theme toggle button ── */
	.theme-toggle {
		cursor: pointer;
		border: 0;
		background: transparent;
		padding: 0.2rem 0.4rem;
		line-height: 1;
		white-space: nowrap;
	}

	.theme-icon {
		display: inline-flex;
		align-items: center;
		vertical-align: middle;
	}

	.theme-icon :global(svg) {
		display: block;
	}

	/* Show sun in dark mode, moon in light mode */
	.icon-moon {
		display: none;
	}

	.theme-toggle[data-theme='light'] .icon-sun {
		display: none;
	}

	.theme-toggle[data-theme='light'] .icon-moon {
		display: contents;
	}

	/* ── Mobile: collapse behind toggle ── */
	@media (max-width: 700px) {
		.nav-toggle-button {
			display: block;
		}

		.nav-links {
			display: none;
			position: absolute;
			top: 100%;
			right: 0;
			flex-direction: column;
			align-items: stretch;
			background: var(--term-bg-bar);
			border: 1px solid var(--term-border);
			border-top: none;
			border-radius: 0 0 6px 6px;
			padding: 0.5rem;
			min-width: 140px;
			z-index: 50;
			box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
		}

		.terminal-nav[data-open='true'] .nav-links {
			display: flex;
		}

		.nav-link {
			padding: 0.4rem 0.6rem;
			font-size: 0.8rem;
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.nav-link,
		.nav-toggle-button {
			transition: none;
		}
	}
</style>
