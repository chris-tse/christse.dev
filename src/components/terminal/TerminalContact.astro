---
interface ContactLink {
	label: string
	href: string
	cmd: string
}

interface Props {
	contactLinks: ContactLink[]
}

const { contactLinks } = Astro.props
---

<section class="block block-contact">
	<p class="cmd-line typed">
		<span class="prompt" aria-hidden="true">$</span> christse --contact --list
	</p>
	<div class="output contact-grid">
		{
			contactLinks.map((link) => (
				<a
					href={link.href}
					target={link.href.startsWith('mailto:') ? undefined : '_blank'}
					rel={
						link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'
					}
					class="contact-entry"
				>
					<span class="contact-cmd">{link.cmd}</span>
					<span class="contact-label">{link.label}</span>
					<span class="contact-arrow">&rarr;</span>
				</a>
			))
		}
	</div>
</section>

<style>
	.block {
		margin-bottom: 2rem;
	}

	.cmd-line {
		margin: 0;
		font-size: 0.88rem;
		white-space: pre-wrap;
	}

	.prompt {
		color: #39ff14;
		font-weight: 700;
		margin-right: 0.5rem;
		user-select: none;
	}

	.contact-grid {
		display: grid;
		gap: 0.4rem;
		margin: 0.5rem 0 0 1.25rem;
		padding-left: 0.75rem;
		border-left: 2px solid #1d2433;
		font-size: 0.88rem;
	}

	.contact-entry {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		padding: 0.65rem 0.85rem;
		border: 1px solid #1d2433;
		border-radius: 4px;
		background: #0a0e14;
		color: #acb2c0;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.contact-entry:hover {
		border-color: #39ff14;
		background: #0f1520;
	}

	.contact-cmd {
		color: #d2a6ff;
		font-size: 0.78rem;
		font-weight: 600;
	}

	.contact-label {
		color: #e6e1cf;
		font-weight: 600;
		font-size: 0.88rem;
	}

	.contact-arrow {
		margin-left: auto;
		color: #39ff14;
		font-size: 0.82rem;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	.contact-entry:hover .contact-arrow {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-entry,
		.contact-arrow {
			transition: none;
			opacity: 1;
		}
	}
</style>
