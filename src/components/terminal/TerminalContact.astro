---
interface ContactLink {
	label: string
	href: string
	cmd: string
}

interface Props {
	contactLinks: ContactLink[]
}

const { contactLinks } = Astro.props
---

<section class="block block-contact">
	<p class="cmd-line typed">
		<span class="prompt" aria-hidden="true">$</span> christse --contact --list
	</p>
	<div class="output contact-grid">
		{
			contactLinks.map((link) => (
				<a
					href={link.href}
					target={link.href.startsWith('mailto:') ? undefined : '_blank'}
					rel={
						link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'
					}
					class="contact-entry"
				>
					<span class="contact-cmd">{link.cmd}</span>
					<span class="contact-label">{link.label}</span>
					<span class="contact-arrow">&rarr;</span>
				</a>
			))
		}
	</div>
</section>

<style>
	/* Component-specific styles only — shared classes from terminal.css */
	.contact-grid {
		display: grid;
		gap: 0.4rem;
		margin: 0.5rem 0 0 1.25rem;
		padding-left: 0.75rem;
		border-left: 2px solid var(--term-border);
		font-size: 0.88rem;
	}

	.contact-entry {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
		text-decoration: none;
		padding: 0.65rem 0.85rem;
		border: 1px solid var(--term-border);
		border-radius: 4px;
		background: var(--term-bg-deepest);
		color: var(--term-text-output);
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.contact-entry:hover {
		border-color: var(--term-green);
		background: var(--term-bg-hover);
	}

	.contact-entry:focus-visible {
		border-color: var(--term-green);
		background: var(--term-bg-hover);
		outline: 1px solid var(--term-green);
		outline-offset: 1px;
	}

	.contact-entry:focus-visible .contact-arrow {
		opacity: 1;
	}

	.contact-cmd {
		color: var(--term-purple);
		font-size: 0.78rem;
		font-weight: 600;
	}

	.contact-label {
		color: var(--term-text-bright);
		font-weight: 600;
		font-size: 0.88rem;
	}

	.contact-arrow {
		margin-left: auto;
		color: var(--term-green);
		font-size: 0.82rem;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	.contact-entry:hover .contact-arrow {
		opacity: 1;
	}

	@media (max-width: 700px) {
		.contact-grid {
			margin-left: 0.75rem;
			padding-left: 0.5rem;
		}

		.contact-arrow {
			opacity: 1;
		}
	}

	@media (max-width: 480px) {
		.contact-grid {
			margin-left: 0.25rem;
			padding-left: 0.35rem;
		}

		.contact-entry {
			padding: 0.5rem 0.6rem;
			gap: 0.5rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-entry,
		.contact-arrow {
			transition: none;
			opacity: 1;
		}
	}
</style>
