---
interface Props {
	heading: string
	paragraphs: string[]
}

const { heading, paragraphs } = Astro.props
---

<section class="block block-about" aria-label="About">
	<p class="cmd-line">
		<span class="prompt" aria-hidden="true">$</span> cat about.md
	</p>
	<div class="output md-output">
		<p class="md-heading">
			<span class="md-hash" aria-hidden="true">##</span>
			{heading}
		</p>
		{paragraphs.map((text) => <p>{text}</p>)}
	</div>
</section>
