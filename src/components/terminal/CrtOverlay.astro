<div class="scanlines" aria-hidden="true"></div>

<style>
	/* ── CRT / Scanline effects ── */
	.scanlines {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 100;
		background: repeating-linear-gradient(
			to bottom,
			transparent 0px,
			transparent 2px,
			rgb(var(--term-scanline-rgb) / 0.12) 2px,
			rgb(var(--term-scanline-rgb) / 0.12) 4px
		);
	}

	@media (prefers-color-scheme: light) {
		.scanlines {
			background: repeating-linear-gradient(
				to bottom,
				transparent 0px,
				transparent 2px,
				rgb(var(--term-scanline-rgb) / 0.06) 2px,
				rgb(var(--term-scanline-rgb) / 0.06) 4px
			);
		}
	}

	:root[data-theme='light'] .scanlines {
		background: repeating-linear-gradient(
			to bottom,
			transparent 0px,
			transparent 2px,
			rgb(var(--term-scanline-rgb) / 0.06) 2px,
			rgb(var(--term-scanline-rgb) / 0.06) 4px
		);
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.scanlines {
			display: none;
		}
	}
</style>
