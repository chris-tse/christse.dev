<div class="scanlines" aria-hidden="true"></div>
<div class="crt-flicker" aria-hidden="true"></div>

<style>
	/* ── CRT / Scanline effects ── */
	.scanlines {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 100;
		background: repeating-linear-gradient(
			to bottom,
			transparent 0px,
			transparent 2px,
			rgba(0, 0, 0, 0.12) 2px,
			rgba(0, 0, 0, 0.12) 4px
		);
	}

	.crt-flicker {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 99;
		will-change: opacity;
		animation: flicker 8s infinite;
	}

	@keyframes flicker {
		0%,
		100% {
			opacity: 0;
		}
		3% {
			opacity: 0.04;
			background: rgba(57, 255, 20, 0.015);
		}
		6% {
			opacity: 0;
		}
		42% {
			opacity: 0;
		}
		44% {
			opacity: 0.02;
			background: rgba(57, 255, 20, 0.01);
		}
		46% {
			opacity: 0;
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.crt-flicker {
			animation: none;
			transition: none;
			opacity: 0;
		}
	}
</style>
