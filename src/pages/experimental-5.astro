---
import '../styles/global.css'
import workHistory from '../data/work-history.json'
import projects from '../data/projects.json'

const title = 'Chris Tse - Experimental 5'
const description =
	'A terminal/CLI-inspired portfolio concept with monospace type, typed-out text animations, and a dark hacker aesthetic.'

const skills = [
	'React',
	'TypeScript',
	'Next.js',
	'Node.js',
	'GraphQL',
	'Performance',
	'Accessibility',
	'Kubernetes',
]

const asciiName = [
	' ██████╗██╗  ██╗██████╗ ██╗███████╗    ████████╗███████╗███████╗',
	'██╔════╝██║  ██║██╔══██╗██║██╔════╝    ╚══██╔══╝██╔════╝██╔════╝',
	'██║     ███████║██████╔╝██║███████╗       ██║   ███████╗█████╗  ',
	'██║     ██╔══██║██╔══██╗██║╚════██║       ██║   ╚════██║██╔══╝  ',
	'╚██████╗██║  ██║██║  ██║██║███████║       ██║   ███████║███████╗',
	' ╚═════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═╝╚══════╝       ╚═╝   ╚══════╝╚══════╝',
]

const contactLinks = [
	{ label: 'github', href: 'https://github.com/christse', cmd: 'open' },
	{
		label: 'linkedin',
		href: 'https://www.linkedin.com/in/christse',
		cmd: 'open',
	},
	{ label: 'email', href: 'mailto:hello@christse.dev', cmd: 'compose' },
]

const latestRole = workHistory[0]

const toolNames = ['Edit', 'Bash', 'Task']
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="scanlines" aria-hidden="true"></div>
		<div class="crt-flicker" aria-hidden="true"></div>

		<div class="terminal">
			<header class="terminal-bar">
				<div class="bar-dots">
					<span class="dot dot-red"></span>
					<span class="dot dot-yellow"></span>
					<span class="dot dot-green"></span>
				</div>
				<p class="bar-title">christse@portfolio ~ experimental-05</p>
				<div class="bar-spacer"></div>
			</header>

			<main class="terminal-body">
				<section class="block block-boot reveal d1">
					<p class="sys-line">
						<span class="prompt-sys">[system]</span> booting christse.dev v5.0.0 ...
					</p>
					<p class="sys-line">
						<span class="prompt-sys">[system]</span> loading modules: portfolio, career,
						projects, contact
					</p>
					<p class="sys-line success">
						<span class="prompt-sys">[system]</span> ready. type
						<code>help</code> for available commands.
					</p>
				</section>

				<section class="block block-ascii reveal d2" aria-label="Chris Tse">
					<div class="ascii-art">
						{asciiName.map((line) => <pre>{line}</pre>)}
					</div>
					<p class="cmd-line">
						<span class="prompt">$</span> cat tagline.md
					</p>
					<div class="output md-output">
						<p class="md-heading">
							<span class="md-hash">##</span> Frontend Engineer
						</p>
						<p>
							I build accessible, high-performance interfaces with a strong bias
							toward clarity and speed. From performance audits to greenfield
							launches, I focus on making experiences feel fast and teams more
							productive.
						</p>
					</div>
				</section>

				<section class="block block-skills reveal d3">
					<p class="cmd-line typed">
						<span class="prompt">$</span> ls ~/skills/
					</p>
					<div class="output skill-grid">
						{
							skills.map((skill, i) => (
								<span class="skill-item" style={`--i: ${i}`}>
									{skill}/
								</span>
							))
						}
					</div>
				</section>

				<section class="block block-career reveal d4">
					<p class="cmd-line typed">
						<span class="prompt">$</span> todo list --career
					</p>
					<div class="output">
						<div class="todo-list" role="list" aria-label="Career history">
							{
								[...workHistory].reverse().map((job, i, arr) => {
									const isActive = i === arr.length - 1
									return (
										<div
											class={`todo-item ${isActive ? 'in-progress' : 'done'}`}
											role="listitem"
										>
											<span class="todo-check">{isActive ? '>' : 'x'}</span>
											<div class="todo-content">
												<div class="todo-title-row">
													<span class="todo-title">
														{job.title} @ {job.employer}
													</span>
													<span
														class={`todo-badge ${isActive ? 'badge-active' : 'badge-done'}`}
													>
														{isActive ? 'in_progress' : 'completed'}
													</span>
												</div>
												<span class="todo-meta">{job.dateRange}</span>
												{isActive && (
													<div class="subagent-block">
														<div class="subagent-header">
															<span class="subagent-icon">Task</span>
															<span class="subagent-label">
																Expand '{latestRole?.title}'
															</span>
															<span class="subagent-meta">
																subagent: explore | status: working
															</span>
														</div>
														<div class="subagent-body">
															{latestRole?.description.map((item, idx) => (
																<div class="tool-call-pair">
																	<div class="tool-call">
																		<div class="tool-call-header">
																			<span class="tool-icon">
																				{toolNames[idx % toolNames.length]}
																			</span>
																		</div>
																	</div>
																	<div class="task-result">
																		<div class="task-result-body">
																			<p>{item}</p>
																		</div>
																	</div>
																</div>
															))}
														</div>
													</div>
												)}
											</div>
										</div>
									)
								})
							}
						</div>
					</div>
				</section>

				<section class="block block-projects reveal d5">
					<p class="cmd-line typed">
						<span class="prompt">$</span> find ~/projects -type f -name "*.ship"
					</p>
					<div class="output project-list">
						{
							projects.map((project, i) => (
								<a
									href={project.href}
									target="_blank"
									rel="noopener noreferrer"
									class="project-entry"
								>
									<div class="project-header">
										<span class="project-idx">[{i}]</span>
										<span class="project-name">{project.name}</span>
										<span class="project-link">OPEN</span>
									</div>
									<p class="project-desc">{project.description}</p>
									<div class="project-tech">
										{project.technologies.map((tech) => (
											<span class="tech-tag">{tech}</span>
										))}
									</div>
								</a>
							))
						}
					</div>
				</section>

				<section class="block block-contact reveal d6">
					<p class="cmd-line typed">
						<span class="prompt">$</span> christse --contact --list
					</p>
					<div class="output contact-grid">
						{
							contactLinks.map((link) => (
								<a
									href={link.href}
									target={
										link.href.startsWith('mailto:') ? undefined : '_blank'
									}
									rel={
										link.href.startsWith('mailto:')
											? undefined
											: 'noopener noreferrer'
									}
									class="contact-entry"
								>
									<span class="contact-cmd">{link.cmd}</span>
									<span class="contact-label">{link.label}</span>
									<span class="contact-arrow">&rarr;</span>
								</a>
							))
						}
					</div>
				</section>

				<section class="block block-prompt reveal d7">
					<p class="cmd-line">
						<span class="prompt">$</span>
						<span class="cursor"></span>
					</p>
				</section>
			</main>
		</div>

		<footer class="term-footer reveal d7">
			<p>
				Experimental 05 - a terminal/CLI-inspired direction for the homepage.
			</p>
			<p>session: christse.dev | pid: 2026 | built with Astro</p>
		</footer>
	</body>
</html>

<style>
	/* ── Base ── */
	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		min-height: 100vh;
		background: #0a0e14;
		color: #b3b1ad;
		font-family: 'JetBrains Mono', monospace;
		line-height: 1.6;
		overflow-x: hidden;
	}

	:global(*) {
		box-sizing: border-box;
	}

	/* ── CRT / Scanline effects ── */
	.scanlines {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 100;
		background: repeating-linear-gradient(
			to bottom,
			transparent 0px,
			transparent 2px,
			rgba(0, 0, 0, 0.12) 2px,
			rgba(0, 0, 0, 0.12) 4px
		);
	}

	.crt-flicker {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 99;
		animation: flicker 8s infinite;
	}

	@keyframes flicker {
		0%,
		100% {
			opacity: 0;
		}
		3% {
			opacity: 0.04;
			background: rgba(57, 255, 20, 0.015);
		}
		6% {
			opacity: 0;
		}
		42% {
			opacity: 0;
		}
		44% {
			opacity: 0.02;
			background: rgba(57, 255, 20, 0.01);
		}
		46% {
			opacity: 0;
		}
	}

	/* ── Terminal chrome ── */
	.terminal {
		width: min(960px, calc(100vw - 2rem));
		margin: 2rem auto 0;
		border: 1px solid #1d2433;
		border-radius: 8px 8px 0 0;
		overflow: hidden;
		box-shadow:
			0 0 80px rgba(57, 255, 20, 0.04),
			0 2px 40px rgba(0, 0, 0, 0.5);
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 1rem;
		background: #151a24;
		border-bottom: 1px solid #1d2433;
	}

	.bar-dots {
		display: flex;
		gap: 6px;
	}

	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}

	.dot-red {
		background: #ff5f57;
	}

	.dot-yellow {
		background: #febc2e;
	}

	.dot-green {
		background: #28c840;
	}

	.bar-title {
		margin: 0;
		font-size: 0.72rem;
		color: #5c6773;
		letter-spacing: 0.03em;
	}

	.bar-spacer {
		flex: 1;
	}

	.terminal-body {
		padding: 1.5rem;
		background: #0d1117;
		min-height: 60vh;
	}

	/* ── Prompt and output styling ── */
	.prompt {
		color: #39ff14;
		font-weight: 700;
		margin-right: 0.5rem;
		user-select: none;
	}

	.prompt-sys {
		color: #e6b450;
		font-weight: 600;
		margin-right: 0.35rem;
	}

	.cmd-line,
	.sys-line {
		margin: 0;
		font-size: 0.88rem;
		white-space: pre-wrap;
	}

	.sys-line.success {
		color: #39ff14;
	}

	.sys-line.success code {
		background: #1a2b1a;
		padding: 0.1rem 0.4rem;
		border-radius: 3px;
		color: #7ee787;
	}

	.output {
		margin: 0.5rem 0 0 1.25rem;
		padding-left: 0.75rem;
		border-left: 2px solid #1d2433;
		color: #acb2c0;
		font-size: 0.88rem;
	}

	.output p {
		margin: 0;
		max-width: 68ch;
	}

	/* ── Blocks / sections ── */
	.block {
		margin-bottom: 2rem;
	}

	.block-boot {
		margin-bottom: 1.5rem;
	}

	.block-boot .sys-line + .sys-line {
		margin-top: 0.15rem;
	}

	/* ── ASCII art ── */
	.ascii-art {
		overflow-x: auto;
		margin-bottom: 0.75rem;
	}

	.ascii-art pre {
		margin: 0;
		font-size: clamp(0.38rem, 1.1vw, 0.68rem);
		line-height: 1.15;
		color: #39ff14;
		text-shadow: 0 0 12px rgba(57, 255, 20, 0.3);
		white-space: pre;
	}

	/* ── Markdown output ── */
	.md-output p {
		margin: 0;
	}

	.md-heading {
		font-size: 1.2rem;
		font-weight: 700;
		color: #e6e1cf;
		margin-bottom: 0.4rem;
	}

	.md-hash {
		color: #5c6773;
		margin-right: 0.35rem;
		font-weight: 400;
	}

	/* ── Skills ── */
	.skill-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1.2rem;
		border-left: 2px solid #1d2433;
	}

	.skill-item {
		color: #7ee787;
		font-size: 0.88rem;
		animation: typeIn 0.3s ease forwards;
		animation-delay: calc(var(--i) * 0.06s);
		opacity: 0;
	}

	@keyframes typeIn {
		to {
			opacity: 1;
		}
	}

	/* ── Career todo list ── */
	.todo-list {
		display: grid;
		gap: 0;
		font-size: 0.86rem;
	}

	.todo-item {
		display: flex;
		align-items: flex-start;
		gap: 0.65rem;
		padding: 0.55rem 0;
		border-bottom: 1px dashed #141a24;
	}

	.todo-item.done {
		opacity: 0.55;
	}

	.todo-item.in-progress {
		opacity: 1;
		background: linear-gradient(
			90deg,
			rgba(89, 194, 255, 0.04) 0%,
			transparent 100%
		);
		padding-left: 0.5rem;
		margin-left: -0.5rem;
		border-left: 2px solid #59c2ff;
		border-bottom: none;
	}

	.todo-check {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.4rem;
		height: 1.4rem;
		border-radius: 3px;
		font-size: 0.72rem;
		font-weight: 800;
		margin-top: 0.1rem;
		line-height: 1;
	}

	.done .todo-check {
		border: 1px solid #2a3040;
		color: #3d4455;
		background: #0a0e14;
		text-decoration: line-through;
	}

	.in-progress .todo-check {
		border: 1px solid #59c2ff;
		color: #59c2ff;
		background: #0f1520;
		animation: pulse-glow 2s ease-in-out infinite;
	}

	@keyframes pulse-glow {
		0%,
		100% {
			box-shadow: 0 0 4px rgba(89, 194, 255, 0.15);
		}
		50% {
			box-shadow: 0 0 10px rgba(89, 194, 255, 0.35);
		}
	}

	.todo-content {
		flex: 1;
		min-width: 0;
	}

	.todo-title-row {
		display: flex;
		align-items: baseline;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.todo-title {
		color: #acb2c0;
		font-weight: 500;
	}

	.done .todo-title {
		text-decoration: line-through;
		text-decoration-color: #2a3040;
	}

	.in-progress .todo-title {
		color: #e6e1cf;
		text-decoration: none;
		font-weight: 600;
	}

	.todo-badge {
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.12rem 0.45rem;
		border-radius: 3px;
	}

	.badge-done {
		color: #3d4455;
		background: #141a24;
		border: 1px solid #1d2433;
	}

	.badge-active {
		color: #59c2ff;
		background: #0f1520;
		border: 1px solid #1a2a3a;
	}

	.todo-meta {
		display: block;
		margin-top: 0.15rem;
		font-size: 0.72rem;
		color: #3d4455;
		letter-spacing: 0.04em;
	}

	.in-progress .todo-meta {
		color: #5c6773;
	}

	/* ── Subagent block (nested inside in-progress item) ── */
	.subagent-block {
		margin-top: 0.65rem;
		border-left: 2px solid #2a3a50;
		border-radius: 0;
		overflow: hidden;
	}

	.subagent-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.4rem 0.75rem;
		background: transparent;
		border-bottom: 1px dashed #1d2433;
		flex-wrap: wrap;
	}

	.subagent-icon {
		flex-shrink: 0;
		font-size: 0.68rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #d2a6ff;
		background: #1a1228;
		border: 1px solid #2a1f3d;
		padding: 0.12rem 0.45rem;
		border-radius: 3px;
	}

	.subagent-label {
		font-size: 0.82rem;
		color: #acb2c0;
		font-weight: 600;
	}

	.subagent-meta {
		margin-left: auto;
		font-size: 0.62rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #3d4455;
	}

	.subagent-body {
		padding: 0.5rem 0.75rem;
		background: transparent;
		display: grid;
		gap: 0.4rem;
	}

	/* ── Tool call pairs inside subagent ── */

	.tool-call-pair {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.6fr);
		gap: 0;
		border: 1px solid #1d2433;
		border-radius: 4px;
		overflow: hidden;
	}

	.tool-call {
		border-right: 1px solid #1d2433;
		background: #131820;
	}

	.tool-call-header {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.55rem 0.75rem;
		height: 100%;
	}

	.tool-icon {
		flex-shrink: 0;
		font-size: 0.68rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #d2a6ff;
		background: #1a1228;
		border: 1px solid #2a1f3d;
		padding: 0.12rem 0.45rem;
		border-radius: 3px;
	}

	.tool-desc {
		font-size: 0.78rem;
		color: #acb2c0;
		font-weight: 500;
	}

	.task-result {
		background: #0a0e14;
	}

	.task-result-header {
		display: flex;
		align-items: center;
		padding: 0.25rem 0.75rem 0;
	}

	.result-status {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #39ff14;
		opacity: 0.5;
	}

	.task-result-body {
		padding: 0.15rem 0.75rem 0.55rem;
	}

	.task-result-body p {
		margin: 0;
		font-size: 0.82rem;
		color: #8b919e;
		line-height: 1.5;
	}

	/* ── Projects ── */
	.project-list {
		display: grid;
		gap: 0.5rem;
		border-left: 2px solid #1d2433;
	}

	.project-entry {
		display: block;
		text-decoration: none;
		color: inherit;
		padding: 0.85rem 1rem;
		border: 1px solid #1d2433;
		border-radius: 4px;
		background: #0a0e14;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.project-entry:hover {
		border-color: #39ff14;
		background: #0f1520;
		box-shadow: 0 0 20px rgba(57, 255, 20, 0.06);
	}

	.project-header {
		display: flex;
		align-items: baseline;
		gap: 0.65rem;
	}

	.project-idx {
		color: #5c6773;
		font-size: 0.78rem;
	}

	.project-name {
		color: #e6e1cf;
		font-weight: 700;
		font-size: 0.95rem;
	}

	.project-link {
		margin-left: auto;
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #39ff14;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	.project-entry:hover .project-link {
		opacity: 1;
	}

	.project-desc {
		margin: 0.4rem 0 0.6rem;
		font-size: 0.82rem;
		color: #6c7080;
