---
import '../styles/global.css'
import workHistory from '../data/work-history.json'
import projects from '../data/projects.json'

const title = 'Chris Tse - Experimental 4'
const description =
	'A blueprint-inspired homepage concept with technical diagrams, grid overlays, and a calmer product-systems aesthetic.'

const metrics = [
	{
		value: '7+',
		label: 'Years building frontend products',
	},
	{
		value: '80%',
		label: 'INP reduction from performance optimization work',
	},
	{
		value: '50%',
		label: 'Faster releases after platform migration work',
	},
]

const signals = [
	{
		title: 'Primary stack',
		text: 'React, TypeScript, Next.js, performance analysis, design systems, and frontend architecture.',
	},
	{
		title: 'Working style',
		text: 'Clear interfaces, reliable systems, and pragmatic collaboration across design and engineering.',
	},
	{
		title: 'Outside work',
		text: 'Keyboard builds, anime, games, Japanese study, and side projects like FiguTrack.',
	},
]

const contactLinks = [
	{
		label: 'GitHub',
		href: 'https://github.com/christse',
	},
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/christse',
	},
	{
		label: 'X',
		href: 'https://twitter.com/christse',
	},
	{
		label: 'Email',
		href: 'mailto:hello@christse.dev',
	},
]
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="canvas-grid" aria-hidden="true"></div>
		<div class="halo halo-a" aria-hidden="true"></div>
		<div class="halo halo-b" aria-hidden="true"></div>

		<header class="hero shell">
			<div class="hero-intro reveal fade-1">
				<p class="kicker">Experimental Concept / 04</p>
				<h1>
					Chris Tse
					<span>Frontend Engineer</span>
				</h1>
				<p class="hero-copy">
					A blueprint-style homepage concept focused on systems thinking,
					performance, and product craft rather than a traditional portfolio
					stack.
				</p>
			</div>

			<div class="hero-layout">
				<section
					class="panel radar-panel reveal fade-2"
					aria-label="Core focus diagram"
				>
					<div class="radar-core">
						<p class="panel-label">Core Focus</p>
						<p class="radar-title">
							Frontend systems that feel fast and stay maintainable.
						</p>
						<div class="radar-tags">
							<span>React</span>
							<span>TypeScript</span>
							<span>Performance</span>
							<span>Accessibility</span>
						</div>
					</div>
					<div class="orbit orbit-1"></div>
					<div class="orbit orbit-2"></div>
					<div class="node node-a">DX</div>
					<div class="node node-b">UI Systems</div>
					<div class="node node-c">Product Thinking</div>
				</section>

				<div class="hero-side reveal fade-3">
					<section class="panel brief-panel">
						<p class="panel-label">Operating Notes</p>
						<ul>
							<li>Build for clarity before complexity.</li>
							<li>Use performance as a product quality signal.</li>
							<li>Leave teams with better systems than before.</li>
						</ul>
					</section>

					<section class="panel available-panel">
						<p class="panel-label">Current Inputs</p>
						<p>
							Shipping web products, tuning side projects, and rotating between
							games, anime, and keyboard builds.
						</p>
					</section>
				</div>
			</div>

			<div
				class="metric-row reveal fade-4"
				role="list"
				aria-label="Selected impact metrics"
			>
				{
					metrics.map((metric) => (
						<article class="panel metric-card" role="listitem">
							<p class="metric-value">{metric.value}</p>
							<p class="metric-label">{metric.label}</p>
						</article>
					))
				}
			</div>
		</header>

		<main class="shell stack">
			<section class="module reveal fade-2">
				<div class="module-head">
					<p class="module-tag">System Overview</p>
					<h2>A frontend approach built around durable product decisions.</h2>
				</div>
				<div class="overview-grid">
					<div class="panel overview-copy">
						<p>
							I like the kind of frontend work where implementation quality
							changes how a product feels: reducing interaction lag, simplifying
							state flows, improving maintainability, and helping teams ship
							with less friction.
						</p>
						<p>
							That usually means balancing UX, engineering constraints, and
							long-term system health rather than treating them as competing
							goals.
						</p>
					</div>
					<div class="signal-grid">
						{
							signals.map((signal) => (
								<article class="panel signal-card">
									<p class="panel-label">{signal.title}</p>
									<p>{signal.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="module reveal fade-3">
				<div class="module-head">
					<p class="module-tag">Career Map</p>
					<h2>
						A route from early web work to product-scale frontend engineering.
					</h2>
				</div>
				<div class="timeline-shell">
					<div class="timeline-line" aria-hidden="true"></div>
					<div class="timeline-grid" role="list">
						{
							workHistory.map((job, index) => (
								<article class="panel timeline-card" role="listitem">
									<div class="timeline-marker">0{index + 1}</div>
									<p class="timeline-date">{job.dateRange}</p>
									<h3>{job.title}</h3>
									<p class="timeline-company">{job.employer}</p>
									<ul>
										{job.description.slice(0, 2).map((item) => (
											<li>{item}</li>
										))}
									</ul>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="module reveal fade-4">
				<div class="module-head">
					<p class="module-tag">Project Modules</p>
					<h2>Selected builds, talks, and tools.</h2>
				</div>
				<div class="project-grid" role="list">
					{
						projects.map((project, index) => (
							<a
								class="panel project-card"
								href={project.href}
								target="_blank"
								rel="noopener noreferrer"
								role="listitem"
							>
								<p class="project-index">Module 0{index + 1}</p>
								<h3>{project.name}</h3>
								<p>{project.description}</p>
								<div class="tech-row">
									{project.technologies.map((tech) => (
										<span>{tech}</span>
									))}
								</div>
							</a>
						))
					}
				</div>
			</section>

			<section class="module reveal fade-4">
				<div class="module-head">
					<p class="module-tag">Open Channel</p>
					<h2>
						Available for conversations about frontend, performance, and product
						craft.
					</h2>
				</div>
				<div class="contact-grid">
					<div class="panel contact-copy">
						<p>
							If your team cares about speed, accessibility, maintainability,
							and UX at the same time, that is usually the kind of problem space
							I enjoy most.
						</p>
					</div>
					<div class="contact-links">
						{
							contactLinks.map((link) => (
								<a
									class="panel contact-link"
									href={link.href}
									target={
										link.href.startsWith('mailto:') ? undefined : '_blank'
									}
									rel={
										link.href.startsWith('mailto:')
											? undefined
											: 'noopener noreferrer'
									}
								>
									<span>{link.label}</span>
									<span class="contact-state">Open</span>
								</a>
							))
						}
					</div>
				</div>
			</section>
		</main>

		<footer class="shell footer">
			<p>Experimental 04 - blueprint interface direction.</p>
			<p>Astro, responsive layout, and reduced-motion support included.</p>
		</footer>
	</body>
</html>

<style>
	:root {
		--bg: #edf4f8;
		--panel: rgba(250, 253, 255, 0.78);
		--panel-strong: rgba(241, 249, 252, 0.92);
		--line: rgba(26, 69, 86, 0.22);
		--line-strong: rgba(26, 69, 86, 0.5);
		--ink: #14303c;
		--muted: #426473;
		--accent: #1d8ca0;
		--accent-soft: rgba(29, 140, 160, 0.12);
		--shadow: rgba(17, 52, 64, 0.08);
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		min-height: 100vh;
		color: var(--ink);
		font-family: 'Chakra Petch', sans-serif;
		background:
			radial-gradient(
				circle at top left,
				rgba(99, 191, 208, 0.22),
				transparent 28%
			),
			radial-gradient(
				circle at 88% 18%,
				rgba(135, 203, 146, 0.22),
				transparent 22%
			),
			linear-gradient(180deg, #f5fafc 0%, #edf4f8 48%, #e7f0f5 100%);
	}

	:global(*) {
		box-sizing: border-box;
	}

	.canvas-grid,
	.halo {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.canvas-grid {
		background-image:
			linear-gradient(to right, rgba(26, 69, 86, 0.08) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(26, 69, 86, 0.08) 1px, transparent 1px);
		background-size: 32px 32px;
		opacity: 0.55;
	}

	.halo {
		filter: blur(60px);
		opacity: 0.5;
	}

	.halo-a {
		background: radial-gradient(
			circle at 18% 14%,
			rgba(29, 140, 160, 0.26),
			transparent 20%
		);
	}

	.halo-b {
		background: radial-gradient(
			circle at 82% 78%,
			rgba(103, 177, 123, 0.2),
			transparent 22%
		);
	}

	.shell {
		position: relative;
		z-index: 1;
		width: min(1180px, calc(100vw - 2rem));
		margin: 0 auto;
	}

	.hero {
		padding: 2rem 0 1.1rem;
	}

	.hero-intro {
		max-width: 58rem;
		margin-bottom: 1.25rem;
	}

	.kicker,
	.panel-label,
	.module-tag,
	.timeline-date,
	.project-index,
	.contact-state,
	.footer p {
		font-family: 'Spline Sans Mono', monospace;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.kicker,
	.module-tag,
	.panel-label {
		margin: 0 0 0.7rem;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--accent);
	}

	h1,
	h2,
	h3,
	.radar-title,
	.metric-value {
		margin: 0;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	h1 {
		font-size: clamp(3.5rem, 10vw, 7rem);
		line-height: 0.9;
	}

	h1 span {
		display: block;
		font-size: clamp(1.1rem, 2vw, 1.65rem);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
		margin-top: 0.65rem;
	}

	.hero-copy {
		margin: 1rem 0 0;
		max-width: 44rem;
		font-size: clamp(1rem, 1.8vw, 1.25rem);
		line-height: 1.65;
		color: var(--muted);
	}

	.hero-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.45fr) minmax(300px, 0.72fr);
		gap: 1rem;
	}

	.panel {
		position: relative;
		background: var(--panel);
		backdrop-filter: blur(14px);
		border: 1px solid var(--line);
		border-radius: 1.6rem;
		box-shadow: 0 20px 40px -30px var(--shadow);
		overflow: hidden;
	}

	.panel::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		border: 1px dashed rgba(26, 69, 86, 0.16);
		margin: 0.55rem;
		pointer-events: none;
	}

	.radar-panel {
		min-height: 29rem;
		padding: 1.5rem;
		background:
			radial-gradient(
				circle at center,
				rgba(29, 140, 160, 0.08),
				transparent 42%
			),
			var(--panel-strong);
		display: grid;
		place-items: center;
	}

	.radar-core {
		position: relative;
		z-index: 2;
		width: min(22rem, 70vw);
		aspect-ratio: 1;
		border-radius: 999px;
		border: 1px solid var(--line-strong);
		background: rgba(248, 253, 255, 0.72);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 2rem;
	}

	.radar-title {
		font-size: clamp(1.7rem, 3.2vw, 2.7rem);
		line-height: 1.02;
		max-width: 9ch;
	}

	.radar-tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 1.1rem;
	}

	.radar-tags span,
	.tech-row span {
		padding: 0.38rem 0.7rem;
		border-radius: 999px;
		border: 1px solid rgba(26, 69, 86, 0.24);
		background: rgba(255, 255, 255, 0.72);
		font-family: 'Spline Sans Mono', monospace;
		font-size: 0.76rem;
		text-transform: uppercase;
	}

	.orbit {
		position: absolute;
		border-radius: 999px;
		border: 1px solid rgba(29, 140, 160, 0.25);
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		animation: orbit-spin 18s linear infinite;
	}

	.orbit-1 {
		width: min(31rem, 94%);
		aspect-ratio: 1;
	}

	.orbit-2 {
		width: min(38rem, 108%);
		aspect-ratio: 1;
		animation-direction: reverse;
		animation-duration: 28s;
	}

	.node {
		position: absolute;
		padding: 0.55rem 0.8rem;
		border-radius: 999px;
		border: 1px solid rgba(26, 69, 86, 0.22);
		background: rgba(247, 253, 255, 0.92);
		font-family: 'Spline Sans Mono', monospace;
		font-size: 0.75rem;
		text-transform: uppercase;
		z-index: 2;
	}

	.node-a {
		top: 16%;
		right: 11%;
	}

	.node-b {
		bottom: 20%;
		left: 8%;
	}

	.node-c {
		bottom: 11%;
		right: 18%;
	}

	.hero-side {
		display: grid;
		gap: 1rem;
	}

	.brief-panel,
	.available-panel,
	.metric-card,
	.overview-copy,
	.signal-card,
	.timeline-card,
	.project-card,
	.contact-copy,
	.contact-link {
		padding: 1.2rem;
	}

	.brief-panel ul,
	.timeline-card ul {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.6rem;
	}

	.brief-panel li,
	.available-panel p,
	.overview-copy p,
	.signal-card p,
	.timeline-card li,
	.project-card p,
	.contact-copy p,
	.contact-link span {
		font-size: 1rem;
		line-height: 1.65;
		color: var(--muted);
	}

	.metric-row {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.metric-card {
		background: rgba(248, 253, 255, 0.68);
	}

	.metric-value {
		font-size: clamp(2.1rem, 4vw, 3.4rem);
		line-height: 1;
		color: var(--ink);
	}

	.metric-label {
		margin: 0.5rem 0 0;
	}

	.stack {
		display: grid;
		gap: 1rem;
		padding-bottom: 1rem;
	}

	.module {
		display: grid;
		gap: 1rem;
	}

	.module-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: end;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 0.95;
		max-width: 14ch;
	}

	.overview-grid,
	.contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(300px, 0.9fr);
		gap: 1rem;
	}

	.signal-grid,
	.contact-links {
		display: grid;
		gap: 1rem;
	}

	.timeline-shell {
		position: relative;
	}

	.timeline-line {
		position: absolute;
		left: 0;
		right: 0;
		top: 2.2rem;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(26, 69, 86, 0.32),
			transparent
		);
	}

	.timeline-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
	}

	.timeline-card {
		padding-top: 2.8rem;
		min-height: 100%;
	}

	.timeline-marker {
		position: absolute;
		top: 1rem;
		left: 1.2rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 999px;
		border: 1px solid rgba(26, 69, 86, 0.26);
		background: rgba(249, 253, 255, 0.95);
		font-family: 'Spline Sans Mono', monospace;
		font-size: 0.74rem;
		font-weight: 700;
		color: var(--accent);
	}

	.timeline-date,
	.project-index,
	.contact-state {
		margin: 0 0 0.4rem;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--accent);
	}

	h3 {
		font-size: 1.55rem;
		line-height: 1;
	}

	.timeline-company {
		margin: 0.45rem 0 0;
		font-weight: 600;
		color: var(--ink);
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		text-decoration: none;
		color: inherit;
		min-height: 100%;
		transition:
			transform 0.25s ease,
			border-color 0.25s ease,
			box-shadow 0.25s ease;
	}

	.project-card:hover,
	.contact-link:hover {
		transform: translateY(-4px);
		border-color: rgba(29, 140, 160, 0.34);
		box-shadow: 0 24px 36px -28px rgba(17, 52, 64, 0.16);
	}

	.tech-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: auto;
	}

	.contact-links {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.contact-link {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: center;
		text-decoration: none;
		transition:
			transform 0.25s ease,
			border-color 0.25s ease,
			box-shadow 0.25s ease;
	}

	.contact-link span:first-child {
		color: var(--ink);
		font-weight: 600;
	}

	.footer {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0 0 2rem;
	}

	.footer p {
		margin: 0;
		font-size: 0.72rem;
		color: var(--muted);
	}

	.reveal {
		opacity: 0;
		animation: reveal 0.7s ease forwards;
	}

	.fade-1 {
		animation-delay: 0.04s;
	}

	.fade-2 {
		animation-delay: 0.12s;
	}

	.fade-3 {
		animation-delay: 0.2s;
	}

	.fade-4 {
		animation-delay: 0.28s;
	}

	@keyframes reveal {
		from {
			opacity: 0;
			transform: translateY(18px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes orbit-spin {
		from {
			transform: translate(-50%, -50%) rotate(0deg);
		}

		to {
			transform: translate(-50%, -50%) rotate(360deg);
		}
	}

	@media (max-width: 1040px) {
		.hero-layout,
		.overview-grid,
		.contact-grid,
		.project-grid,
		.timeline-grid {
			grid-template-columns: minmax(0, 1fr);
		}

		.contact-links {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.timeline-line {
			display: none;
		}
	}

	@media (max-width: 720px) {
		.hero {
			padding-top: 1.4rem;
		}

		.metric-row,
		.contact-links {
			grid-template-columns: minmax(0, 1fr);
		}

		.module-head,
		.footer {
			flex-direction: column;
			align-items: start;
		}

		.radar-panel {
			min-height: 24rem;
		}

		.radar-core {
			width: min(18rem, 76vw);
			padding: 1.3rem;
		}

		.node-a {
			top: 10%;
			right: 4%;
		}

		.node-b {
