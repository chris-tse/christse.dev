---
/**
 * Terminal-themed blog post page (redesign)
 *
 * Parallel to /blog/[slug] -- same content collection, terminal layout.
 * Once finalised, this replaces src/pages/blog/[...slug].astro.
 */
import { getCollection, render } from 'astro:content'
import TerminalBlogPostLayout from '../../layouts/TerminalBlogPostLayout.astro'

export async function getStaticPaths() {
	const posts = await getCollection('posts')
	return posts.map((entry) => ({
		params: { slug: entry.id.replace(/\.mdx$/, '') },
		props: { entry },
	}))
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<TerminalBlogPostLayout
	title={entry.data.title}
	pubDate={entry.data.publishedAt.toDateString() ?? null}
	heroImage={entry.data.coverImage ?? null}
	description={entry.data.description ?? null}
	socialImage={entry.data.coverImage ?? null}
>
	<Content />
</TerminalBlogPostLayout>
