const contactLinks = [
	{ label: 'github', href: 'https://github.com/christse', cmd: 'open' },
	{
		label: 'linkedin',
		href: 'https://www.linkedin.com/in/christse',
		cmd: 'open',
	},
	{ label: 'x / twitter', href: 'https://x.com/ChrisMTse', cmd: 'open' },
	{ label: 'email', href: 'mailto:hello@christse.dev', cmd: 'compose' },
	{ label: 'resume', href: '/resume.pdf', cmd: 'download' },
]

const profileInfo = [
	{ key: 'name', value: 'Chris Tse' },
	{ key: 'role', value: 'Frontend Engineer' },
	{ key: 'exp', value: '8+ years' },
	{ key: 'stack', value: 'React, TypeScript, Next.js' },
	{ key: 'focus', value: 'Performance & Accessibility' },
	{ key: 'status', value: 'Building fast, accessible UIs' },
]

const aboutHeading = 'About Me'
const aboutParagraphs = [
	"I'm a frontend engineer with 7+ years of experience building modern web applications. I specialize in React, TypeScript, and responsive design, with a strong focus on creating accessible and performant user interfaces.",
	"When I'm not coding, you can find me engaging in my local tech community through organizing meetups and mentoring aspiring developers. You can also find me at the gym, practicing my Japanese, or just enjoying a fun video game with friends.",
]
---

<TerminalLayout
	title="Chris Tse - Frontend Engineer"
	canonical="https://christse.dev/"
>
	<CrtOverlay />

	<TerminalWindow>
		<TerminalNav slot="nav" />

		<div id="main-content">
			<TerminalBoot version={siteVersion} />

			<TerminalHero asciiName={asciiName} info={profileInfo} />

			<div id="about">
				<TerminalAbout heading={aboutHeading} paragraphs={aboutParagraphs} />
			</div>

			<div id="skills">
				<TerminalSkills skills={skills} />
			</div>

			<TerminalCareer workHistory={workHistory} />

			<div id="projects">
				<TerminalProjects projects={projects} />
			</div>

			<div id="contact">
				<TerminalContact contactLinks={contactLinks} />
			</div>

			<TerminalPrompt />
		</div>
	</TerminalWindow>

	<TerminalFooter />
</TerminalLayout>
