---
import { ViewTransitions } from 'astro:transitions'
import '../styles/global.css'
import workHistory from '../data/work-history.json'
import projects from '../data/projects.json'

const title = 'Chris Tse - Frontend Engineer'
const description =
	'Frontend engineer with 7+ years building for the web. Keyboard enthusiast, PC builder, and anime fan.'
---

<!doctype html>
<html lang="en">
	<head>
		<ViewTransitions />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-[#FAF8F3] text-gray-900 min-h-screen">
		<!-- Hero Section -->
		<header class="max-w-4xl mx-auto px-6 py-16 md:py-24">
			<div class="space-y-6">
				<h1 class="text-5xl md:text-7xl font-bold tracking-tight">
					Chris Tse
					<span class="block text-2xl md:text-3xl font-normal text-gray-600 mt-2"
						><span class="typewriter">よろしく</span></span
					>
				</h1>
				<p
					class="text-2xl md:text-3xl text-gray-700 max-w-2xl leading-relaxed font-light"
				>
					Frontend engineer who builds fast, accessible web experiences — and
					appreciates a good mechanical keyboard.
				</p>
			</div>
		</header>

		<main class="max-w-4xl mx-auto px-6 pb-16 space-y-20">
			<!-- About Me Section -->
			<section class="space-y-6">
				<h2
					class="text-3xl md:text-4xl font-semibold text-gray-900 border-b-2 border-[#E8A598] pb-3 inline-block"
				>
					About Me
				</h2>
				<div class="prose prose-lg max-w-none">
					<p class="text-lg text-gray-700 leading-relaxed">
						I'm a frontend engineer with <strong>7+ years of experience</strong>
						building modern web applications. I specialize in React, TypeScript, and
						responsive design, with a strong focus on creating accessible and performant
						user interfaces.
					</p>
					<p class="text-lg text-gray-700 leading-relaxed">
						When I'm not coding, you can find me engaging in my local tech community
						through organizing meetups and mentoring aspiring developers. You can also
						find me at the gym, practicing my Japanese, or just enjoying a fun video
						game with friends.
					</p>
				</div>
			</section>

			<!-- Work Section - Timeline -->
			<section class="space-y-6">
				<div class="flex justify-between items-end border-b-2 border-[#E8A598] pb-3">
					<h2 class="text-3xl md:text-4xl font-semibold text-gray-900">
						Work Experience
					</h2>
					<a
						href="/resume.pdf"
						download
						class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition-colors text-sm whimsical-link"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="mr-2"
						>
							<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
							<polyline points="7 10 12 15 17 10"></polyline>
							<line x1="12" y1="15" x2="12" y2="3"></line>
						</svg>
						Download Resume
					</a>
				</div>
				<div class="relative">
					{
						workHistory.map((job, index) => (
							<div class="relative pl-8 border-l-2 border-[#E8A598]/30 pb-8 last:pb-0">
								<!-- Timeline dot - positioned exactly on the border line -->
								<div 
									class={`absolute w-4 h-4 rounded-full -left-[9px] top-2 transition-transform hover:scale-125 ${
										index === 0 
											? 'bg-[#E8A598] border-4 border-[#E8A598]' 
											: 'bg-white border-4 border-[#9BB89F]'
									}`}
								></div>
								
								<div class="flex flex-col sm:flex-row sm:items-center justify-between mb-2">
									<h3 class="text-xl font-semibold text-gray-900">{job.title}</h3>
									<span class="text-sm text-[#E8A598] font-medium">{job.dateRange}</span>
								</div>
								<div class="text-gray-600 mb-3">{job.employer}</div>
								<ul class="space-y-2 text-gray-700">
									{job.description.map((item) => (
										<li class="flex items-start text-sm">
											<span class="text-[#9BB89F] mr-2 mt-1">•</span>
											<span>{item}</span>
										</li>
									))}
									</ul>
								</div>
							)
							)
						}
					</div>
				</section>

				<!-- Projects Section -->
				<section class="space-y-6">
					<h2
						class="text-3xl md:text-4xl font-semibold text-gray-900 border-b-2 border-[#9BB89F] pb-3 inline-block"
					>
						Featured Projects
					</h2>
					<div class="grid md:grid-cols-2 gap-6">
						{
							projects.map((project) => (
								<a
									href={project.href}
									target="_blank"
									rel="noopener noreferrer"
									class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 transition-all duration-300 block tilt-card"
								>
									<h3 class="text-xl font-semibold mb-2 text-gray-900">{project.name}</h3>
									<p class="text-gray-700 mb-4">{project.description}</p>
									<div class="flex flex-wrap gap-2">
										{project.technologies.map((tech) => (
											<span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
												{tech}
											</span>
										))}
									</div>
								</a>
								)
								)
							}
						</div>
					</section>

					<!-- Currently Playing Section -->
					<section class="space-y-6">
						<h2
							class="text-3xl md:text-4xl font-semibold text-gray-900 border-b-2 border-[#E8A598] pb-3 inline-block"
						>
							Currently Playing
						</h2>
						<div class="grid md:grid-cols-2 gap-6">
							<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 transition-all duration-300 tilt-card">
								<h3 class="text-xl font-semibold mb-4 text-[#E8A598]">🎮 Gaming</h3>
								<p class="text-gray-700 mb-3">
									Always juggling a handful of gacha games:
								</p>
								<ul class="space-y-2 text-gray-700">
									<li>• Honkai: Star Rail</li>
									<li>• Zenless Zone Zero</li>
									<li>• Genshin Impact (on and off)</li>
								</ul>
							</div>
							<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 transition-all duration-300 tilt-card">
								<h3 class="text-xl font-semibold mb-4 text-[#E8A598]">📺 Watching</h3>
								<ul class="space-y-2 text-gray-700">
									<li>• Frieren: Beyond Journey's End</li>
									<li>• Dungeon Meshi (Delicious in Dungeon)</li>
									<li>• Re-watching Cowboy Bebop</li>
								</ul>
							</div>
						</div>
					</section>

					<!-- My Setup Section -->
					<section class="space-y-6">
						<h2
							class="text-3xl md:text-4xl font-semibold text-gray-900 border-b-2 border-[#E8A598] pb-3 inline-block"
						>
							My Setup
						</h2>
						<div class="space-y-6">
							<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 transition-all duration-300 tilt-card">
								<h3 class="text-xl font-semibold mb-4 text-[#9BB89F]">
									⌨️ Keyboard
								</h3>
								<div class="text-gray-700 space-y-2">
									<p>
										<strong>Board:</strong> Custom 65% (Tofu65 case, DZ65RGB PCB)
									</p>
									<p><strong>Switches:</strong> Gateron Ink Black V2 (lubed)</p>
									<p><strong>Keycaps:</strong> GMK Olivia++</p>
								</div>
							</div>

							<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 transition-all duration-300 tilt-card">
								<h3 class="text-xl font-semibold mb-4 text-[#9BB89F]">🖥️ PC</h3>
								<div class="grid md:grid-cols-2 gap-4 text-gray-700">
									<div>
										<p><strong>CPU:</strong> AMD Ryzen 7 5800X3D</p>
										<p><strong>GPU:</strong> NVIDIA RTX 3080</p>
										<p><strong>RAM:</strong> 32GB DDR4 3600MHz</p>
									</div>
									<div>
										<p><strong>Storage:</strong> 2TB NVMe SSD</p>
										<p><strong>Case:</strong> NZXT H510 Elite</p>
										<p><strong>Monitor:</strong> LG 27" 1440p 165Hz</p>
									</div>
								</div>
							</div>

							<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 transition-all duration-300 tilt-card">
								<h3 class="text-xl font-semibold mb-4 text-[#9BB89F]">
									💻 Dev Tools
								</h3>
								<div class="text-gray-700 space-y-2">
									<p><strong>Editor:</strong> VS Code (with vim keybindings)</p>
									<p>
										<strong>Terminal:</strong> Warp / iTerm2 with Starship prompt
									</p>
									<p><strong>Theme:</strong> Tokyo Night / Catppuccin</p>
									<p><strong>Font:</strong> JetBrains Mono</p>
								</div>
							</div>
						</div>
					</section>

					<!-- Contact Section -->
					<section class="space-y-6">
						<h2
							class="text-3xl md:text-4xl font-semibold text-gray-900 border-b-2 border-[#9BB89F] pb-3 inline-block"
						>
							Let's Connect
						</h2>
						<div class="space-y-4">
							<p class="text-lg text-gray-700 leading-relaxed">
								Always happy to chat about web dev, keyboards, anime, or gaming.
								Feel free to reach out!
							</p>
							<div class="flex flex-wrap gap-4">
								<a
									href="https://github.com/christse"
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors shadow-sm"
								>
									<svg
										class="w-5 h-5 mr-2"
										fill="currentColor"
										viewBox="0 0 24 24"
										aria-hidden="true"
									>
										<path
											fill-rule="evenodd"
											d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
											clip-rule="evenodd"></path>
									</svg>
									GitHub
								</a>
								<a
									href="https://twitter.com/christse"
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center px-6 py-3 bg-black text-white rounded-lg hover:bg-gray-800 transition-colors shadow-sm"
								>
									<svg
										class="w-5 h-5 mr-2"
										fill="currentColor"
										viewBox="0 0 24 24"
										aria-hidden="true"
									>
										<path
											d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
										></path>
									</svg>
									X / Twitter
								</a>
								<a
									href="https://www.linkedin.com/in/christse"
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center px-6 py-3 bg-[#0A66C2] text-white rounded-lg hover:bg-[#0958a8] transition-colors shadow-sm"
								>
									<svg
										class="w-5 h-5 mr-2"
										fill="currentColor"
										viewBox="0 0 24 24"
										aria-hidden="true"
									>
										<path
											d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"
										></path>
									</svg>
									LinkedIn
								</a>
								<a
									href="mailto:hello@christse.dev"
									class="inline-flex items-center px-6 py-3 bg-white text-gray-900 rounded-lg hover:bg-gray-50 transition-colors shadow-sm border border-gray-300"
								>
									<svg
										class="w-5 h-5 mr-2"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
										aria-hidden="true"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
										></path>
									</svg>
									Email
								</a>
							</div>
						</div>
					</section>
				</main>

				<!-- Footer -->
				<footer class="max-w-4xl mx-auto px-6 py-12 border-t border-gray-300">
					<p class="text-center text-gray-600">
						Built with <span class="text-[#E8A598]">♥</span> using Astro & Tailwind
						CSS
					</p>
					<p class="text-center text-sm text-gray-500 mt-2">
						© {new Date().getFullYear()} Chris Tse. またね！
					</p>
				</footer>
			</body>
		</html>

		<style>
			:global(html) {
				scroll-behavior: smooth;
			}

			@media (prefers-reduced-motion: reduce) {
				:global(html) {
					scroll-behavior: auto;
				}
				.typewriter {
					animation: none;
					width: auto;
					border-right: none;
				}
				.tilt-card {
					transform: none !important;
				}
			}

			/* Typewriter effect for よろしく */
			@keyframes typing {
				from { width: 0; }
				to { width: 4.5ch; }
			}
			@keyframes blink-caret {
				from, to { border-color: transparent; }
				50% { border-color: #E8A598; }
			}
			.typewriter {
				display: inline-block;
				overflow: hidden;
				white-space: nowrap;
				border-right: 2px solid #E8A598;
				animation: 
					typing 0.6s steps(4, end) 0.5s forwards,
					blink-caret 0.8s step-end infinite;
				width: 0;
			}

			/* 3D Card tilt on hover */
			.tilt-card {
				transform-style: preserve-3d;
				transform: perspective(1000px) rotateX(0) rotateY(0);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			.tilt-card:hover {
				transform: perspective(1000px) rotateX(-2deg) rotateY(2deg) translateY(-4px);
				box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.15);
			}

			/* Whimsical link underlines */
			.whimsical-link {
				position: relative;
				text-decoration: none;
			}
			.whimsical-link::after {
				content: '';
				position: absolute;
				width: 100%;
				height: 2px;
				bottom: -2px;
				left: 0;
				background-color: #E8A598;
				transform: scaleX(0);
				transform-origin: bottom right;
				transition: transform 0.3s ease, background-color 0.3s ease;
			}
			.whimsical-link:hover::after {
				transform: scaleX(1);
				transform-origin: bottom left;
				background-color: #9BB89F;
			}

			/* Gentle pulse for active timeline dot */
			@keyframes gentle-pulse {
				0%, 100% { box-shadow: 0 0 0 0 rgba(232, 165, 152, 0.4); }
				50% { box-shadow: 0 0 0 6px rgba(232, 165, 152, 0); }
			}
			.bg-\[\#E8A598\]\.border-4\.border-\[\#E8A598\] {
				animation: gentle-pulse 2s ease-in-out infinite;
			}
		</style>