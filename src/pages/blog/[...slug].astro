---
/**
 * Terminal-themed blog post page
 *
 * Renders individual blog posts from the content collection
 * with the terminal layout.
 */
import { getCollection, render } from 'astro:content'
import TerminalBlogPostLayout from '../../layouts/TerminalBlogPostLayout.astro'
import { getSlug } from '../../utils/blog'

export async function getStaticPaths() {
	const posts = await getCollection('posts', (entry) =>
		import.meta.env.PROD ? !entry.data.draft : true,
	)
	return posts.map((entry) => ({
		params: { slug: getSlug(entry.id) },
		props: { entry },
	}))
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<TerminalBlogPostLayout
	title={entry.data.title}
	pubDate={entry.data.publishedAt.toDateString() ?? null}
	heroImage={entry.data.coverImage ?? null}
	description={entry.data.description ?? null}
	socialImage={entry.data.coverImage ?? null}
>
	<Content />
</TerminalBlogPostLayout>
