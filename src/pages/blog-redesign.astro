---
/**
 * Terminal-themed blog listing page (redesign)
 *
 * Parallel to /blog -- uses the same content collection but rendered
 * with the new terminal aesthetic. Once finalised, this replaces
 * src/pages/blog.astro and moves to /blog.
 *
 * TODO: Replace Layout import with TerminalLayout once it exists.
 */
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('posts')
const sortedPosts = posts.sort((a, b) => {
	return (
		new Date(b.data.publishedAt).valueOf() -
		new Date(a.data.publishedAt).valueOf()
	)
})

const getSlug = (id: string) => id.replace(/\.mdx$/, '')
---

<Layout
	title="Blog"
	navigationHrefs={{
		about: '/#about',
		projects: '/#projects',
		contact: '/#contact',
	}}
>
	<main class="max-w-3xl flex-1 w-full px-6 py-12 mx-auto md:px-10">
		<!-- TODO: Terminal-themed blog listing (ls ~/blog/) -->
		<section>
			<h1 class="text-2xl font-bold mb-8 font-mono">$ ls ~/blog/</h1>
			{
				sortedPosts.map((post) => {
					const slug = getSlug(post.id)
					return (
						<article class="mb-10">
							<h2>
								<a
									class="text-lg font-mono hover:underline"
									href={`/blog-redesign/${slug}`}
								>
									{post.data.title}
								</a>
							</h2>
							<time class="block text-sm mb-2 opacity-60 font-mono">
								{new Date(post.data.publishedAt).toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'numeric',
									day: 'numeric',
								})}
							</time>
							<p class="font-mono text-sm opacity-80">
								{post.data.description}
							</p>
						</article>
					)
				})
			}
		</section>
	</main>
</Layout>
