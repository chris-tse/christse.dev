---
import '../styles/global.css'
import workHistory from '../data/work-history.json'
import projects from '../data/projects.json'

const title = 'Chris Tse - Experimental 3'
const description =
	'A poster-inspired homepage concept with bold section bands, oversized typography, and a more graphic portfolio system.'

const impactStats = [
	{
		value: '80%',
		label: 'INP reduction through performance audits and optimization work',
	},
	{
		value: '50%',
		label: 'Faster feature releases after unifying multiple brand applications',
	},
	{
		value: '10%',
		label:
			'Lead conversion lift from ML-powered search and sorting improvements',
	},
]

const principles = [
	'Ship interfaces that feel fast before they look flashy.',
	'Build with accessibility and resilience as product features, not cleanup work.',
	'Leave teams with better systems, clearer code, and less friction.',
]

const sideQuests = [
	{
		title: 'Right now',
		items: [
			'Building FiguTrack, a local-first home for anime figure pre-orders.',
			'Practicing Japanese and keeping a steady gym routine.',
		],
	},
	{
		title: 'On screen',
		items: [
			'Playing Honkai: Star Rail and Zenless Zone Zero.',
			'Watching Frieren, Dungeon Meshi, and revisiting Cowboy Bebop.',
		],
	},
	{
		title: 'At the desk',
		items: [
			'Custom keyboards, PC building, and tuning dev workflows.',
			'React, TypeScript, performance, and frontend architecture.',
		],
	},
]

const contactLinks = [
	{
		label: 'GitHub',
		href: 'https://github.com/christse',
	},
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/christse',
	},
	{
		label: 'X',
		href: 'https://twitter.com/christse',
	},
	{
		label: 'Email',
		href: 'mailto:hello@christse.dev',
	},
]
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="poster-grid" aria-hidden="true">
			<span></span>
			<span></span>
			<span></span>
		</div>

		<header class="hero-band">
			<div class="hero-shell">
				<div class="hero-copy reveal rise-1">
					<p class="eyebrow">Experimental Concept / 03</p>
					<h1>
						Chris
						<span>Tse</span>
					</h1>
					<p class="role">
						Frontend engineer building fast, reliable product experiences.
					</p>
					<p class="lede">
						This concept treats the homepage like a printed poster system: loud
						type, stacked color bands, and content that reads more like signals
						than sections.
					</p>
				</div>

				<div class="hero-aside reveal rise-2">
					<div class="stamp-card tilt">
						<p class="stamp-label">Focus</p>
						<p class="stamp-value">
							React, TypeScript, performance, and frontend systems.
						</p>
					</div>
					<div class="stamp-card tilt alt">
						<p class="stamp-label">Based around</p>
						<p class="stamp-value">
							Clarity, accessibility, and shipping work teams can keep using.
						</p>
					</div>
				</div>
			</div>

			<div
				class="impact-strip reveal rise-3"
				role="list"
				aria-label="Selected impact"
			>
				{
					impactStats.map((stat) => (
						<article class="impact-card tilt" role="listitem">
							<p class="impact-value">{stat.value}</p>
							<p class="impact-label">{stat.label}</p>
						</article>
					))
				}
			</div>
		</header>

		<main>
			<section class="band manifesto-band">
				<div class="band-shell">
					<p class="section-tag">Manifesto</p>
					<div class="manifesto-grid">
						<div>
							<h2>Make the product feel obvious.</h2>
							<p>
								I like frontend work that removes drag for both users and teams.
								That can mean tightening rendering performance, redesigning a UI
								system, or making a messy workflow easier to ship and maintain.
							</p>
						</div>
						<div class="principles">
							{
								principles.map((principle, index) => (
									<article class="principle-card tilt">
										<p class="principle-index">0{index + 1}</p>
										<p>{principle}</p>
									</article>
								))
							}
						</div>
					</div>
				</div>
			</section>

			<section class="band route-band">
				<div class="band-shell">
					<p class="section-tag">Career Route</p>
					<div class="route-headline">
						<h2>From early web work to large-scale frontend systems.</h2>
						<p>
							A career path shaped by shipping, scaling, and steadily tightening
							the feedback loop between design, code, and performance.
						</p>
					</div>
					<div class="route-list" role="list">
						{
							workHistory.map((job, index) => (
								<article class="route-stop tilt" role="listitem">
									<div class="stop-marker">{index + 1}</div>
									<p class="stop-date">{job.dateRange}</p>
									<h3>{job.title}</h3>
									<p class="stop-company">{job.employer}</p>
									<ul>
										{job.description.slice(0, 2).map((item) => (
											<li>{item}</li>
										))}
									</ul>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="band project-band">
				<div class="band-shell">
					<p class="section-tag">Selected Work</p>
					<div class="projects-headline">
						<h2>Projects presented like a stack of release posters.</h2>
						<p>
							Open any card to jump straight to the live project or write-up.
						</p>
					</div>
					<div class="project-grid" role="list">
						{
							projects.map((project, index) => (
								<a
									class={`project-card tilt tone-${(index % 4) + 1}`}
									href={project.href}
									target="_blank"
									rel="noopener noreferrer"
									role="listitem"
								>
									<p class="project-count">0{index + 1}</p>
									<h3>{project.name}</h3>
									<p>{project.description}</p>
									<div class="tech-line">
										{project.technologies.map((tech) => (
											<span>{tech}</span>
										))}
									</div>
								</a>
							))
						}
					</div>
				</div>
			</section>

			<section class="band life-band">
				<div class="band-shell">
					<p class="section-tag">Off Clock</p>
					<div class="life-grid">
						<div class="life-copy">
							<h2>The other inputs.</h2>
							<p>
								Outside of work I am usually rotating between games, anime,
								keyboard parts, and side projects. The thread through all of it
								is the same: I like systems that are fun to tune.
							</p>
						</div>
						<div class="ticket-grid">
							{
								sideQuests.map((group) => (
									<article class="ticket-card tilt">
										<p class="ticket-title">{group.title}</p>
										<ul>
											{group.items.map((item) => (
												<li>{item}</li>
											))}
										</ul>
									</article>
								))
							}
						</div>
					</div>
				</div>
			</section>

			<section class="band contact-band">
				<div class="band-shell contact-shell">
					<p class="section-tag">Contact</p>
					<div class="contact-copy">
						<h2>If you want product-minded frontend help, say hello.</h2>
						<p>
							I enjoy work where performance, UX, and engineering quality all
							matter at the same time.
						</p>
					</div>
					<div class="contact-links">
						{
							contactLinks.map((link) => (
								<a
									href={link.href}
									target={
										link.href.startsWith('mailto:') ? undefined : '_blank'
									}
									rel={
										link.href.startsWith('mailto:')
											? undefined
											: 'noopener noreferrer'
									}
								>
									<span>{link.label}</span>
									<span class="link-arrow">Open</span>
								</a>
							))
						}
					</div>
				</div>
			</section>
		</main>

		<footer>
			<p>
				Experimental 03 - a graphic, poster-style direction for the homepage.
			</p>
			<p>Built with Astro and tuned for desktop and mobile.</p>
		</footer>
	</body>
</html>

<style>
	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		min-height: 100vh;
		background: linear-gradient(
			180deg,
			#f3ead8 0%,
			#f3ead8 17%,
			#ed6645 17%,
			#ed6645 44%,
			#1f6c7b 44%,
			#1f6c7b 72%,
			#efe7da 72%,
			#efe7da 100%
		);
		color: #171717;
		font-family: 'IBM Plex Sans', sans-serif;
	}

	:global(*) {
		box-sizing: border-box;
	}

	.poster-grid {
		position: fixed;
		inset: 0;
		pointer-events: none;
		opacity: 0.16;
		background-image:
			linear-gradient(to right, rgba(23, 23, 23, 0.16) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(23, 23, 23, 0.12) 1px, transparent 1px);
		background-size: 24px 24px;
	}

	.poster-grid span {
		position: absolute;
		display: block;
		border: 2px solid rgba(23, 23, 23, 0.18);
		border-radius: 999px;
	}

	.poster-grid span:nth-child(1) {
		width: 12rem;
		height: 12rem;
		top: 4rem;
		right: 7vw;
	}

	.poster-grid span:nth-child(2) {
		width: 18rem;
		height: 18rem;
		bottom: 16rem;
		left: -6rem;
	}

	.poster-grid span:nth-child(3) {
		width: 10rem;
		height: 10rem;
		bottom: 5rem;
		right: 12vw;
	}

	.hero-band,
	.band,
	footer {
		position: relative;
		z-index: 1;
	}

	.hero-shell,
	.band-shell,
	footer {
		width: min(1180px, calc(100vw - 2rem));
		margin: 0 auto;
	}

	.hero-band {
		padding: 1.2rem 0 1.5rem;
	}

	.hero-shell {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.8fr);
		gap: 1.25rem;
		align-items: end;
	}

	.hero-copy,
	.stamp-card,
	.impact-card,
	.principle-card,
	.route-stop,
	.project-card,
	.ticket-card,
	.contact-links a {
		border: 2px solid #171717;
		box-shadow: 8px 8px 0 #171717;
	}

	.hero-copy {
		padding: 1.5rem 1.5rem 1.35rem;
		background: #f9f3e8;
	}

	.eyebrow,
	.section-tag,
	.stamp-label,
	.stop-date,
	.project-count,
	.ticket-title,
	.link-arrow,
	footer p {
		font-family: 'IBM Plex Mono', monospace;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.82rem;
		font-weight: 700;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-weight: 400;
		line-height: 0.92;
		text-transform: uppercase;
		font-family: 'Bebas Neue', sans-serif;
	}

	h1 {
		font-size: clamp(4.8rem, 17vw, 11rem);
		letter-spacing: 0.03em;
	}

	h1 span {
		display: block;
		color: #ed6645;
	}

	.role {
		margin: 0.8rem 0 0;
		font-size: clamp(1.05rem, 2.3vw, 1.5rem);
		font-weight: 700;
		max-width: 26ch;
	}

	.lede {
		margin: 0.9rem 0 0;
		max-width: 54ch;
		font-size: 1rem;
		line-height: 1.65;
	}

	.hero-aside {
		display: grid;
		gap: 1rem;
	}

	.stamp-card {
		padding: 1.1rem;
		background: #ffe09d;
	}

	.stamp-card.alt {
		background: #bde7ea;
	}

	.stamp-label {
		margin: 0 0 0.55rem;
		font-size: 0.78rem;
		font-weight: 700;
	}

	.stamp-value {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.5;
		font-weight: 600;
	}

	.impact-strip {
		width: min(1180px, calc(100vw - 2rem));
		margin: 1rem auto 0;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.impact-card {
		padding: 1rem 1rem 1.15rem;
		background: #f9f3e8;
	}

	.impact-value {
		margin: 0;
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 0.9;
	}

	.impact-label {
		margin: 0.55rem 0 0;
		font-size: 0.95rem;
		line-height: 1.5;
		max-width: 28ch;
	}

	.band {
		padding: 1rem 0;
	}

	.band-shell {
		display: grid;
		grid-template-columns: 180px minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}

	.section-tag {
		position: sticky;
		top: 1rem;
		margin: 0;
		font-size: 0.82rem;
		font-weight: 700;
		padding: 0.9rem 1rem;
		background: rgba(23, 23, 23, 0.08);
		border: 2px solid #171717;
	}

	.manifesto-grid,
	.life-grid,
	.contact-shell {
		display: grid;
		gap: 1rem;
	}

	.manifesto-grid {
		grid-template-columns: minmax(0, 1fr) minmax(360px, 0.95fr);
	}

	.manifesto-grid h2,
	.route-headline h2,
	.projects-headline h2,
	.life-copy h2,
	.contact-copy h2 {
		font-size: clamp(2.4rem, 6vw, 4.6rem);
		line-height: 0.94;
	}

	.manifesto-grid p,
	.route-headline p,
	.life-copy p,
	.contact-copy p,
	.project-card p,
	.route-stop li,
	.ticket-card li {
		font-size: 1rem;
		line-height: 1.65;
	}

	.principles {
		display: grid;
		gap: 1rem;
	}

	.principle-card {
		display: grid;
		grid-template-columns: 72px minmax(0, 1fr);
		gap: 1rem;
		padding: 1rem;
		background: #f9f3e8;
	}

	.principle-index {
		margin: 0;
		font-family: 'Bebas Neue', sans-serif;
		font-size: 3rem;
		line-height: 0.88;
		color: #ed6645;
	}

	.principle-card p:last-child {
		margin: 0;
	}

	.route-headline,
	.projects-headline {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: end;
		margin-bottom: 1rem;
	}

	.projects-headline p {
		margin: 0;
		max-width: 30ch;
		font-weight: 700;
	}

	.route-list {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
	}

	.route-stop {
		position: relative;
		padding: 1rem;
		background: #f9f3e8;
		min-height: 100%;
	}

	.stop-marker {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.3rem;
		height: 2.3rem;
		border-radius: 999px;
		background: #171717;
		color: #f9f3e8;
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.82rem;
		font-weight: 700;
	}

	.stop-date {
		margin: 0.9rem 0 0.35rem;
		font-size: 0.72rem;
		font-weight: 700;
	}

	.route-stop h3 {
		font-size: 2rem;
		line-height: 0.98;
	}

	.stop-company {
		margin: 0.5rem 0 0;
		font-weight: 700;
	}

	.route-stop ul,
	.ticket-card ul {
		margin: 0.8rem 0 0;
		padding-left: 1.1rem;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem;
		min-height: 280px;
		text-decoration: none;
		color: inherit;
	}

	.project-card h3 {
		font-size: 2.5rem;
		line-height: 0.94;
	}

	.project-count {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 700;
	}

	.project-card > p:nth-of-type(2) {
		margin: 0;
		max-width: 36ch;
	}

	.tech-line {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.tech-line span {
		padding: 0.38rem 0.65rem;
		border: 1px solid rgba(23, 23, 23, 0.6);
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.78rem;
		text-transform: uppercase;
	}

	.tone-1 {
		background: #ffe09d;
	}

	.tone-2 {
		background: #ffd2d2;
	}

	.tone-3 {
		background: #bde7ea;
	}

	.tone-4 {
		background: #f9f3e8;
	}

	.ticket-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.ticket-card {
		padding: 1rem;
		background: #f9f3e8;
	}

	.ticket-title {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
	}

	.contact-shell {
		grid-template-columns: 180px minmax(0, 1fr) minmax(280px, 0.9fr);
	}

	.contact-links {
		display: grid;
		gap: 0.85rem;
	}

	.contact-links a {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: center;
		padding: 1rem;
		background: #f9f3e8;
		color: #171717;
		text-decoration: none;
		font-weight: 700;
	}

	.link-arrow {
		font-size: 0.78rem;
	}

	footer {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.6rem 0 2rem;
	}

	footer p {
		margin: 0;
		font-size: 0.76rem;
		font-weight: 500;
	}

	.tilt {
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}

	.tilt:hover {
		transform: translate(-4px, -4px);
		box-shadow: 12px 12px 0 #171717;
	}

	.reveal {
		opacity: 0;
		animation: reveal 0.7s ease forwards;
	}

	.rise-1 {
		animation-delay: 0.06s;
	}

	.rise-2 {
		animation-delay: 0.14s;
	}

	.rise-3 {
		animation-delay: 0.22s;
	}

	@keyframes reveal {
		from {
			opacity: 0;
			transform: translateY(18px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 1100px) {
		.hero-shell,
		.manifesto-grid,
		.contact-shell {
			grid-template-columns: minmax(0, 1fr);
		}

		.hero-aside,
		.contact-links {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.route-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 820px) {
		.band-shell,
		.contact-shell {
			grid-template-columns: minmax(0, 1fr);
		}

		.section-tag {
			position: static;
		}

		.impact-strip,
		.project-grid,
		.ticket-grid,
		.route-list,
		.hero-aside {
			grid-template-columns: minmax(0, 1fr);
		}

		.route-headline,
		.projects-headline,
		footer {
			flex-direction: column;
			align-items: start;
		}

		h1 {
			font-size: clamp(4.5rem, 28vw, 8rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		:global(html) {
			scroll-behavior: auto;
		}

		.reveal,
		.tilt {
			animation: none;
			transition: none;
			transform: none;
			opacity: 1;
		}
	}
</style>
